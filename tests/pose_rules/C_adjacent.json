{
  "description": "C 类：近邻模式区分。防止相邻姿态定义随时间互相糊化。",
  "cases": [
    {
      "case_id": "C-pe-vs-lpb-A",
      "kind": "C_adjacent",
      "mode": "playful_echo",
      "input": { "recommended_response_mode": "playful_echo" },
      "note": "playful_echo 不应出现 '接梗+轻划线' 这类强约束，但仍然 operational_answer=0。",
      "expect": {
        "hard_constraints_must_not_include_text_fragment": ["轻划线"],
        "fit_score_caps_at_most": { "operational_answer": 0 }
      }
    },
    {
      "case_id": "C-pe-vs-lpb-B",
      "kind": "C_adjacent",
      "mode": "light_playful_boundary",
      "input": { "recommended_response_mode": "light_playful_boundary" },
      "note": "light_playful_boundary 必须包含 '接梗+轻划线' 语义并限制激进动作 ≤ 30。",
      "expect": {
        "hard_constraints_must_include_text_fragment": ["接梗+轻划线"],
        "fit_score_caps_at_most": { "aggressive_action": 30 }
      }
    },
    {
      "case_id": "C-hsp-vs-cp-A",
      "kind": "C_adjacent",
      "mode": "half_serious_probe",
      "input": { "recommended_response_mode": "half_serious_probe" },
      "note": "half_serious_probe 必含 clarifying_probe 且 utterance 以问号结尾。",
      "expect": {
        "required_candidate_types_superset_of": ["clarifying_probe"],
        "expresser_must_end_with_question": true
      }
    },
    {
      "case_id": "C-hsp-vs-cp-B",
      "kind": "C_adjacent",
      "mode": "curious_pivot",
      "input": { "recommended_response_mode": "curious_pivot" },
      "note": "curious_pivot 必含 abstract_pivot；不强制问号结尾。",
      "expect": {
        "required_candidate_types_superset_of": ["abstract_pivot"],
        "expresser_must_end_with_question": false
      }
    },
    {
      "case_id": "C-sb-vs-hb-A",
      "kind": "C_adjacent",
      "mode": "soft_boundary",
      "input": { "recommended_response_mode": "soft_boundary" },
      "note": "soft_boundary 不限制单句；不禁止绕道。",
      "expect": {
        "expresser_sentences_max_not_set_or_ge": 2,
        "hard_constraints_must_not_include_text_fragment": ["禁止绕道"]
      }
    },
    {
      "case_id": "C-sb-vs-hb-B",
      "kind": "C_adjacent",
      "mode": "hard_boundary",
      "input": { "recommended_response_mode": "hard_boundary" },
      "note": "hard_boundary 强制单句 ≤ 30 字，且禁止绕道式回答。",
      "expect": {
        "expresser_sentences_max_at_most": 1,
        "expresser_utterance_max_chars_at_most": 30,
        "hard_constraints_must_include_text_fragment": ["禁止绕道"]
      }
    }
  ]
}
