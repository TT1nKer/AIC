{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicharacter.local/story_distiller/schemas/distilled_package.v0.1.json",
  "title": "DistilledPackage",
  "description": "Story distillation output: characters + relationships + secrets + triggers + sediment. Structure only; no source text, no identifiable lines.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "characters", "relationships", "secrets", "triggers"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "const": "0.1.0" },

    "source_note": {
      "description": "Free-form note about the source material and how abstraction was performed. Not meant to identify the work.",
      "type": "string",
      "maxLength": 500
    },

    "characters": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": { "$ref": "#/$defs/distilled_character" }
    },

    "relationships": {
      "type": "array",
      "maxItems": 20,
      "items": { "$ref": "#/$defs/distilled_relationship" }
    },

    "secrets": {
      "description": "信息不对称结构。每条记录：真相是什么（抽象化）、谁知道多少、谁误以为自己知道。",
      "type": "array",
      "maxItems": 10,
      "items": { "$ref": "#/$defs/distilled_secret" }
    },

    "triggers": {
      "description": "可复用的事件模板。不是具体剧情，是可套进其它世界的触发结构。",
      "type": "array",
      "maxItems": 15,
      "items": { "$ref": "#/$defs/distilled_trigger" }
    }
  },

  "$defs": {
    "distilled_character": {
      "type": "object",
      "additionalProperties": false,
      "description": "Per-character厚度 structure. 8 fields max — the minimum needed to give a character runnable density in AICharacter.",
      "required": [
        "character_id",
        "core_drive",
        "hidden_fact",
        "defense_style",
        "trigger_patterns",
        "cannot_say",
        "sediment_traces"
      ],
      "properties": {
        "character_id": {
          "description": "Anonymous id (A / B / C / pseudo-name). Must NOT be the original work's character name.",
          "type": "string",
          "pattern": "^[A-Za-z0-9_]+$",
          "maxLength": 20
        },

        "role_label": {
          "description": "结构性角色标签，不是职业。如 'the one who carries responsibility' / 'the dependent one' / 'the observer'. 可为空。",
          "type": "string",
          "maxLength": 60
        },

        "core_drive": {
          "description": "角色的核心驱动力：想保住什么 / 最怕失去什么 / 最想被别人怎么看。抽象表述，≤ 3 句，不引用具体情节。",
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": { "type": "string", "maxLength": 80 }
        },

        "hidden_fact": {
          "description": "角色最不愿承认的事、最想被隐瞒的事、或最容易自欺的地方。**结构化陈述**，不是原作情节。≤ 2 句。",
          "type": "array",
          "minItems": 0,
          "maxItems": 2,
          "items": { "type": "string", "maxLength": 80 }
        },

        "defense_style": {
          "description": "当被戳到痛处时，角色如何防御。枚举组合，可多选。",
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "enum": [
              "hard_deflect",
              "minimize_own_suffering",
              "joke_to_escape",
              "change_topic",
              "self_blame_to_shut_down",
              "attack_others",
              "silent_withdrawal",
              "overcompensate_with_competence",
              "intellectualize",
              "deny_then_partial_admit"
            ]
          }
        },

        "trigger_patterns": {
          "description": "哪些情境结构会让这个角色明显变化。**结构描述**而非关键词，例：'being told their pain is exaggerated' / 'being asked for specifics they cannot produce'。",
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": { "type": "string", "maxLength": 80 }
        },

        "cannot_say": {
          "description": "角色对某类内容不能直说/只能含糊的事。1~4 条。",
          "type": "array",
          "minItems": 0,
          "maxItems": 4,
          "items": { "type": "string", "maxLength": 80 }
        },

        "sediment_traces": {
          "description": "留在角色身上的过去痕迹。每条必须**可转成 AICharacter memories 条目**（带 emotion / salience 影响）。1~3 条。禁止引用原作具体情节。",
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["text", "emotion", "salience"],
            "properties": {
              "text": {
                "description": "结构化的过去痕迹描述，≤ 60 字。不含原作具体人名/地名/事件。",
                "type": "string",
                "maxLength": 60
              },
              "emotion": {
                "enum": ["shame", "fear", "anger", "sadness", "grief", "pride", "guilt", "attachment_loss", "betrayal_residue"]
              },
              "salience": {
                "type": "integer",
                "minimum": 40,
                "maximum": 100
              }
            }
          }
        }
      }
    },

    "distilled_relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_id", "to_id", "tension_type", "surface_vs_underneath"],
      "properties": {
        "from_id": { "type": "string" },
        "to_id": { "type": "string" },
        "tension_type": {
          "enum": [
            "owes_something",
            "suspects",
            "depends_on",
            "avoids",
            "sees_as_replacement",
            "cooperates_on_surface_opposes_underneath",
            "protects_from_truth",
            "envies",
            "blames",
            "is_blamed_by"
          ]
        },
        "surface_vs_underneath": {
          "type": "object",
          "additionalProperties": false,
          "required": ["surface", "underneath"],
          "properties": {
            "surface": { "type": "string", "maxLength": 60 },
            "underneath": { "type": "string", "maxLength": 60 }
          }
        },
        "note": { "type": "string", "maxLength": 80 }
      }
    },

    "distilled_secret": {
      "type": "object",
      "additionalProperties": false,
      "required": ["secret_id", "truth_abstracted", "knowledge_map"],
      "properties": {
        "secret_id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "truth_abstracted": {
          "description": "真相的抽象陈述，**不引用原作桥段**。",
          "type": "string",
          "maxLength": 120
        },
        "knowledge_map": {
          "description": "谁知道多少 / 谁误以为自己知道 / 谁在压住信息。",
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["character_id", "knows_level"],
            "properties": {
              "character_id": { "type": "string" },
              "knows_level": {
                "enum": ["full_truth", "partial", "wrong_version", "unaware", "suspects_but_avoids_checking"]
              },
              "attitude": {
                "enum": ["will_volunteer", "will_admit_if_pressed", "will_deflect", "will_deny", "will_kill_topic"]
              }
            }
          }
        }
      }
    },

    "distilled_trigger": {
      "description": "可复用的事件触发模板。不引用原作具体情节，只保留能在新世界中被引用的结构。",
      "type": "object",
      "additionalProperties": false,
      "required": ["trigger_id", "pattern", "likely_effects"],
      "properties": {
        "trigger_id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "pattern": {
          "description": "结构化描述，例：'X 被公开要求在 Y 面前展示他已经失去的能力'。",
          "type": "string",
          "maxLength": 120
        },
        "likely_effects": {
          "description": "事件在角色身上的**状态级**影响（而非剧情走向）。",
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["character_id", "change"],
            "properties": {
              "character_id": { "type": "string" },
              "change": { "type": "string", "maxLength": 60 }
            }
          }
        }
      }
    }
  }
}
