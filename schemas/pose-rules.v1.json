{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicharacter.local/schemas/pose-rules.v1.json",
  "title": "PoseRules",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "modes", "candidate_type_taxonomy", "global"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },

    "modes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "description",
          "priority",
          "required_candidate_types",
          "forbidden_candidate_types",
          "fit_score_caps",
          "decider_constraints",
          "expresser_style"
        ],
        "properties": {
          "description": { "type": "string", "minLength": 1 },
          "priority": {
            "description": "冲突决议顺序。高 priority 覆盖低 priority。不得用于 fit_score。",
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "required_candidate_types": {
            "type": "array",
            "items": { "type": "string" }
          },
          "forbidden_candidate_types": {
            "type": "array",
            "items": { "type": "string" }
          },
          "fit_score_caps": {
            "description": "每个键是 candidate_type 名；特殊通配键 'any_other' 表示未显式列出的其它 candidate_types 的统一上限。'any_other' 仅在 fit_score_caps 中有效，不是 candidate_type_taxonomy 的成员。",
            "type": "object",
            "additionalProperties": { "type": "integer", "minimum": 0, "maximum": 100 }
          },
          "decider_constraints": {
            "type": "array",
            "items": { "$ref": "#/$defs/constraint_line" }
          },
          "expresser_style": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "allow":  { "type": "array", "items": { "type": "string" } },
              "forbid": { "type": "array", "items": { "type": "string" } },
              "utterance_max_chars":          { "type": "integer", "minimum": 0 },
              "utterance_starts_with":        { "type": "array", "items": { "type": "string" } },
              "utterance_ends_with_question": { "type": "boolean" },
              "utterance_may_be_empty":       { "type": "boolean" },
              "sentences_max":                { "type": "integer", "minimum": 1 }
            }
          },
          "tiebreaker_overrides": {
            "oneOf": [
              { "type": "null" },
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "disable_strategy_preferences": { "type": "boolean" }
                }
              }
            ]
          }
        }
      }
    },

    "candidate_type_taxonomy": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },

    "global": {
      "type": "object",
      "additionalProperties": false,
      "required": ["top_level_constraints", "hard_constraints_max", "style_fence_max", "safety_hooks"],
      "properties": {
        "top_level_constraints": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/constraint_line" }
        },
        "hard_constraints_max": { "type": "integer", "minimum": 1 },
        "style_fence_max":      { "type": "integer", "minimum": 1 },
        "safety_hooks": {
          "description": "resolver 使用：当 trigger 满足时，强制抬升到 forced_mode（若其 priority 更高）。trigger 是结构化 DSL，见 $defs/trigger_expr。",
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "trigger", "forced_mode", "src"],
            "properties": {
              "name":        { "type": "string", "minLength": 1 },
              "trigger":     { "$ref": "#/$defs/trigger_expr" },
              "forced_mode": { "type": "string", "minLength": 1 },
              "src":         { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  },

  "$defs": {
    "trigger_expr": {
      "description": "结构化触发表达式。叶子节点是比较操作 (eq/ne/gte/lte/gt/lt)，复合节点是 any_of / all_of / not。path 使用点号访问 ctx 子字段。",
      "oneOf": [
        { "type": "object", "additionalProperties": false, "required": ["eq"],  "properties": { "eq":  { "$ref": "#/$defs/trigger_cmp" } } },
        { "type": "object", "additionalProperties": false, "required": ["ne"],  "properties": { "ne":  { "$ref": "#/$defs/trigger_cmp" } } },
        { "type": "object", "additionalProperties": false, "required": ["gte"], "properties": { "gte": { "$ref": "#/$defs/trigger_cmp" } } },
        { "type": "object", "additionalProperties": false, "required": ["lte"], "properties": { "lte": { "$ref": "#/$defs/trigger_cmp" } } },
        { "type": "object", "additionalProperties": false, "required": ["gt"],  "properties": { "gt":  { "$ref": "#/$defs/trigger_cmp" } } },
        { "type": "object", "additionalProperties": false, "required": ["lt"],  "properties": { "lt":  { "$ref": "#/$defs/trigger_cmp" } } },
        { "type": "object", "additionalProperties": false, "required": ["any_of"], "properties": { "any_of": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/trigger_expr" } } } },
        { "type": "object", "additionalProperties": false, "required": ["all_of"], "properties": { "all_of": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/trigger_expr" } } } },
        { "type": "object", "additionalProperties": false, "required": ["not"],    "properties": { "not": { "$ref": "#/$defs/trigger_expr" } } }
      ]
    },
    "trigger_cmp": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "value"],
      "properties": {
        "path":  { "type": "string", "minLength": 1 },
        "value": { "description": "字符串/数字/布尔/null 均可", "type": ["string", "number", "boolean", "null"] }
      }
    },
    "constraint_line": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "src"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "src":  { "type": "string", "minLength": 1 }
      }
    }
  }
}
